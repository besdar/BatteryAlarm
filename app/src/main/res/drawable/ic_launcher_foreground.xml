<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Battery Alarm App Icon — Foreground Layer

        This is a custom battery icon with a lightning bolt (⚡) symbol inside,
        representing a battery monitoring/alarm app. The design uses the adaptive
        icon safe zone (the inner 66dp circle of the 108dp canvas), so the
        important content stays visible regardless of the device's icon mask shape.

        Design elements:
        1. Battery body — rounded rectangle outline
        2. Battery cap — the positive terminal at the top
        3. Lightning bolt — inside the battery, indicating "alert/power"
    -->

    <!-- Battery cap (the small nub at the top of the battery) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,24 L62,24 L62,29 L46,29 Z" />

    <!-- Battery body (rounded rectangle outline) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,29 C36,29 34,31 34,33 L34,79 C34,81 36,83 38,83 L70,83 C72,83 74,81 74,79 L74,33 C74,31 72,29 70,29 L38,29 Z M38,33 L70,33 L70,79 L38,79 L38,33 Z" />

    <!-- Lightning bolt inside the battery — the "alarm" symbol -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M56,40 L47,57 L52,57 L48,72 L61,52 L55,52 L60,40 Z" />

</vector>
